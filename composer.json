{
  "name": "miguel-devops/bedrock-ship",
  "type": "project",
  "license": "MIT",
  "description": "Production-ready WordPress Docker image — Bedrock + FrankenPHP + Acorn, rootless and lightweight",
  "homepage": "https://github.com/Miguel-DevOps/bedrock-ship",
  "authors": [
    {
      "name": "Scott Walkinshaw",
      "email": "scott.walkinshaw@gmail.com",
      "homepage": "https://github.com/swalkinshaw",
      "role": "Bedrock core"
    },
    {
      "name": "Ben Word",
      "email": "ben@benword.com",
      "homepage": "https://github.com/retlehs",
      "role": "Bedrock core"
    },
    {
      "name": "Miguel Lozano",
      "email": "miguel@developmi.com",
      "homepage": "https://github.com/Miguel-DevOps",
      "role": "Docker distribution & maintainer"
    }
  ],
  "keywords": [
    "bedrock", "wordpress", "docker", "frankenphp", "acorn", "wp", "caddy"
  ],
  "support": {
    "issues": "https://github.com/Miguel-DevOps/bedrock-ship/issues"
  },
  "repositories": [
    {
      "name": "wpackagist",
      "type": "composer",
      "url": "https://wpackagist.org",
      "only": ["wpackagist-plugin/*", "wpackagist-theme/*"]
    }
  ],
  "require": {
    "php": ">=8.3",
    "composer/installers": "^2.2",
    "vlucas/phpdotenv": "^5.5",
    "oscarotero/env": "^2.1",
    "roots/bedrock-autoloader": "^1.0",
    "roots/bedrock-disallow-indexing": "^2.0",
    "roots/wordpress": "6.9.4",
    "roots/wp-config": "1.0.0",
    "roots/acorn": "6.1.0",
    "wpackagist-theme/twentytwentyfive": "^1.0"
  },
  "require-dev": {
    "laravel/pint": "^1.29"
  },
  "config": {
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "platform": {
      "php": "8.3"
    },
    "allow-plugins": {
      "composer/installers": true,
      "roots/wordpress-core-installer": true
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "extra": {
    "installer-paths": {
      "web/app/mu-plugins/{$name}/": ["type:wordpress-muplugin"],
      "web/app/plugins/{$name}/": ["type:wordpress-plugin"],
      "web/app/themes/{$name}/": ["type:wordpress-theme"]
    },
    "wordpress-install-dir": "web/wp"
  },
  "scripts": {
    "lint": "pint --test",
    "lint:fix": "pint"
  }
}
