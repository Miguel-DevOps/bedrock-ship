################################################################################
# Cloud-Native WordPress Boilerplate
# Development Environment Configuration
#
# SECURITY NOTE: This is a template. Create .env from this file and update
# all values according to your environment. NEVER commit .env to version control.
################################################################################

# ═══════════════════════════════════════════════════════════════════════════════
# DATABASE CONFIGURATION (MariaDB)
# ═══════════════════════════════════════════════════════════════════════════════

# Database name (will be created by MariaDB if it doesn't exist)
MARIADB_DATABASE=wordpress_dev

# MariaDB root password (used only during initialization)
# WARNING: Change this to a strong password, especially for production
MARIADB_ROOT_PASSWORD=your_secure_root_password_here

# Application database user (for WordPress connection)
# This user will have permissions only on MARIADB_DATABASE
MARIADB_USER=wordpress_user

# Application database password (must match WordPress config)
# WARNING: Use a strong, random password (min 16 characters recommended)
MARIADB_PASSWORD=your_secure_wordpress_password_here

# Database host (container name in docker-compose, or hostname for external DB)
MARIADB_HOST=mariadb

# ═══════════════════════════════════════════════════════════════════════════════
# WORDPRESS CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════

# WordPress environment (development, staging, production)
WP_ENV=development

# Base URL for WordPress (without trailing slash)
WP_HOME=http://localhost:8080

# WordPress database connection string
# Format: mysql://user:password@host:port/database
# If using default MySQL port (3306), you can omit :3306
DATABASE_URL=mysql://${MARIADB_USER}:${MARIADB_PASSWORD}@${MARIADB_HOST}:3306/${MARIADB_DATABASE}

# WordPress Site URL (typically same as WP_HOME with /wp appended)
WP_SITEURL=${WP_HOME}/wp

# Security salts (generate new ones at https://roots.io/salts.html)
# These are placeholder values - replace with your own
AUTH_KEY=put_your_unique_phrase_here_1
SECURE_AUTH_KEY=put_your_unique_phrase_here_2
LOGGED_IN_KEY=put_your_unique_phrase_here_3
NONCE_KEY=put_your_unique_phrase_here_4
AUTH_SALT=put_your_unique_phrase_here_5
SECURE_AUTH_SALT=put_your_unique_phrase_here_6
LOGGED_IN_SALT=put_your_unique_phrase_here_7
NONCE_SALT=put_your_unique_phrase_here_8

# ═══════════════════════════════════════════════════════════════════════════════
# APPLICATION CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════

# Debug mode (true for development, false for production)
WP_DEBUG=true

# Debug logging (logs to wp-content/debug.log)
WP_DEBUG_LOG=true

# Display debug errors (false for production)
WP_DEBUG_DISPLAY=false

# Host port mapping (change if 8080 is already in use)
APP_PORT=8080

# ═══════════════════════════════════════════════════════════════════════════════
# DATABASE OVERRIDES (optional — used when DATABASE_URL is not set)
# ═══════════════════════════════════════════════════════════════════════════════

# Enable SSL for database connection (set to 1 for TLS)
# DB_SSL=

# WordPress table prefix (default: wp_)
# DB_PREFIX=wp_

# ═══════════════════════════════════════════════════════════════════════════════
# PERFORMANCE & CRON
# ═══════════════════════════════════════════════════════════════════════════════

# Disable WordPress cron (use system cron for production)
# DISABLE_WP_CRON=false

# Limit post revisions (number or false to disable, true for unlimited)
# WP_POST_REVISIONS=true

# ═══════════════════════════════════════════════════════════════════════════════
# OPTIONAL: S3/CLOUD STORAGE (for production uploads)
# ═══════════════════════════════════════════════════════════════════════════════

# Uncomment and configure if using S3 for uploads (production recommended)
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# AWS_DEFAULT_REGION=us-east-1
# AWS_S3_BUCKET=your-bucket-name

# ═══════════════════════════════════════════════════════════════════════════════
# OPTIONAL: REDIS CACHE (for production performance)
# ═══════════════════════════════════════════════════════════════════════════════

# Uncomment if using Redis for caching (production recommended)
# REDIS_HOST=redis
# REDIS_PORT=6379
# REDIS_PASSWORD=your_redis_password

################################################################################
# END OF CONFIGURATION
################################################################################
